APP_ENV=dev
API_PORT=8000
POSTGRES_DB=gpuflow
POSTGRES_USER=gpuflow
POSTGRES_PASSWORD=gpuflow
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://gpuflow:gpuflow@db:5432/gpuflow
JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
LOGIN_GUARD_STATE_TTL_SECONDS=900
LOGIN_GUARD_MAX_STATES=10000
ALLOW_USER_REGISTRATION=true
STRICT_PRODUCTION_CHECKS=true
SLURM_MODE=mock
JUPYTERHUB_MODE=mock
METRICS_MODE=mock
QUEUE_TICK_SECONDS=3
SESSION_TICK_SECONDS=4
WORKERS_ENABLED=true
WORKERS_USE_DB_LOCK=true
QUEUE_START_DELAY_SECONDS=8
QUEUE_START_TIMEOUT_SECONDS=300
SESSION_IDLE_TIMEOUT_SECONDS=120
SESSION_MAX_RUNTIME_SECONDS=2400
ADMIN_WARN_RATE_LIMIT_COUNT=3
ADMIN_WARN_RATE_LIMIT_WINDOW_SECONDS=60
WS_HEARTBEAT_TIMEOUT_SECONDS=45
WS_AUTH_RECHECK_SECONDS=30
CLUSTER_GPU_TOTAL=3
DEFAULT_MAX_ACTIVE_SESSIONS=1
DEFAULT_MAX_QUEUED_REQUESTS=2
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SEED_ON_STARTUP=true
SEED_SYNC_EXISTING_USERS=true
